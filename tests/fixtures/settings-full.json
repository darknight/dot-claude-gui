{
  "env": {
    "NODE_ENV": "production",
    "DEBUG": "0"
  },
  "includeCoAuthoredBy": true,
  "language": "en",
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "1.0.0",
  "skipDangerousModePermissionPrompt": false,
  "permissions": {
    "allow": ["Bash(git:*)", "Read(**)", "Write(src/**)"],
    "deny": ["Bash(rm:-rf *)"],
    "ask": ["Bash(curl:*)"],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo pre-tool-use",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write $CLAUDE_TOOL_OUTPUT_FILE",
            "allowedEnvVars": ["CLAUDE_TOOL_OUTPUT_FILE"]
          }
        ]
      }
    ]
  },
  "deniedMcpServers": [
    {
      "serverName": "untrusted-server"
    }
  ],
  "statusLine": {
    "type": "command",
    "command": "echo ready",
    "padding": 1
  },
  "enabledPlugins": {
    "my-plugin": true,
    "another-plugin": false
  },
  "extraKnownMarketplaces": {
    "test-market": {
      "source": {
        "source": "github",
        "repo": "owner/test-repo"
      }
    }
  },
  "sandbox": {
    "allowRead": ["/home/user/project"],
    "denyRead": ["/etc/passwd"],
    "allowWrite": ["/tmp"],
    "excludedCommands": ["rm"],
    "failIfUnavailable": true,
    "enableWeakerNetworkIsolation": false
  },
  "modelOverrides": {
    "default": "claude-opus-4",
    "background": "claude-haiku-3"
  },
  "tui": "fullscreen",
  "effortLevel": "xhigh",
  "model": "opus",
  "outputStyle": "default",
  "fastMode": true,
  "fastModePerSessionOptIn": false,
  "availableModels": ["sonnet", "opus", "haiku"],
  "autoCompactWindow": 500000,
  "showClearContextOnPlanAccept": true,
  "promptSuggestionEnabled": true,
  "autoMemoryEnabled": true,
  "includeGitInstructions": true,
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "claudeMdExcludes": ["vendor/", ".venv/"],
  "plansDirectory": "~/.claude/plans",
  "syntaxHighlightingDisabled": false,
  "allowedMcpServers": [
    { "serverName": "context7", "serverUrl": "https://mcp.context7.com/mcp" }
  ],
  "enabledMcpjsonServers": ["trusted-a"],
  "disabledMcpjsonServers": ["blocked-a"],
  "enableAllProjectMcpServers": true,
  "allowManagedMcpServersOnly": false,
  "strictKnownMarketplaces": [
    { "source": { "source": "github" }, "repo": "anthropics/claude-plugins" }
  ],
  "blockedMarketplaces": [],
  "skippedMarketplaces": ["some-old-market"],
  "skippedPlugins": ["deprecated-plugin"],
  "pluginTrustMessage": "Only install plugins from vetted marketplaces.",
  "pluginConfigs": {
    "context7@official": { "options": { "apiKey": "xxx" } }
  },
  "skillOverrides": {
    "my-skill": { "disabled": true }
  }
}
